{
  "expo": {
    "name": "Justblr Matrix",
    "slug": "justblr-matrix",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "justblr-matrix",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.justblr.matrix",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record voice commands and notes with accent support",
        "NSContactsUsageDescription": "Pick contacts for reminders"
      }
    },
    "android": {
      "package": "com.justblr.matrix",
      "enableDangerousExperimentalLeanBuilds": false,
      "enableProguardInReleaseBuilds": false,
      "enableShrinkResourcesInReleaseBuilds": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "versionCode": 18
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#667eea",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b8f0a917-5508-4df0-b325-52d02b4d1966"
      }
    }
  },
  "version": "1.5.4"
}
